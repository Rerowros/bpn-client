{
  "name": "badvpn-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rerowros/bpn-client.git"
  },
  "scripts": {
    "dev": "npm --prefix apps/badvpn-client run tauri:dev",
    "run:release": "powershell -ExecutionPolicy Bypass -File scripts/run-release.ps1",
    "build": "npm --prefix apps/badvpn-client run build",
    "tauri:info": "npm --prefix apps/badvpn-client run tauri:info",
    "check": "npm --prefix apps/badvpn-client run check && cargo check --workspace"
  },
  "workspaces": [
    "apps/badvpn-client"
  ]
}
